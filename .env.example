# ══════════════════════════════════════════════════════════════════════
#  $100K Digital Wealth Platform — Environment Variables
# ══════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to source control.
#
# ══════════════════════════════════════════════════════════════════════

# ── Robinhood Crypto API ──────────────────────────────────────────────
# Get from: https://robinhood.com/account/crypto-api-keys
# Run generate_keys.py to create your Ed25519 key pair.
RH_API_KEY=your_api_key_here
RH_PRIVATE_KEY=your_base64_ed25519_private_key_here

# ── Alpaca Markets (Stocks, ETFs, Dividends, Options, Bonds) ─────────
# Free account at: https://alpaca.markets
# Paper trading = simulated, no real money (set ALPACA_PAPER=true)
# Live trading  = real orders (set ALPACA_PAPER=false)
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER=true

# ── Anthropic / Claude AI ─────────────────────────────────────────────
# Used by the AI Signals strategy (BUY/SELL/HOLD via Claude analysis)
# Get from: https://console.anthropic.com
# ~$0.01–0.03 per analysis call. Runs at most every 3 hours.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: News Sentiment (add your key when ready) ───────────────
# NEWSAPI_KEY=your-newsapi-key-here
